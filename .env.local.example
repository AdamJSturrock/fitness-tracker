# Turso (libSQL) connection. For local dev, leave URL set to file:./local.db.
TURSO_DATABASE_URL=file:./local.db
TURSO_AUTH_TOKEN=

# Shared password for the app. Both Adam and Anna use this to log in.
APP_PASSWORD=changeme

# Cookie signing secret. Must be at least 32 characters in production.
COOKIE_SECRET=

# FatSecret platform API credentials (https://platform.fatsecret.com/my-account/api-key).
# Used as a fallback for barcode → nutrition lookups when Open Food Facts has no match.
# Open Food Facts itself needs no key. Leave blank to disable the FatSecret fallback.
FATSECRET_CLIENT_ID=
FATSECRET_CLIENT_SECRET=
